{
  "name": "phpstorm-pack-109",
  "displayName": "PhpStorm Pack 109",
  "description": "Recommended extensions",
  "version": "1.0.0",
  "publisher": "rizort",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Extension Packs"],
  "icon": "icon.png",
  "extensionPack": [
    "rizort.phpstorm-light-theme-109",
    "chadalen.vscode-jetbrains-icon-theme",
    "mrchetan.phpstorm-parameter-hints-in-vscode",
    "phiter.phpstorm-snippets",
    "xdebug.php-debug",
    "bmewburn.vscode-intelephense-client",
    "muath-ye.composer-intelephense",
    "eamodio.gitlens",
    "dotenv.dotenv-vscode",
    "ms-vscode.makefile-tools",
    "github.copilot-chat"
  ],
  "contributes": {
    "configurationDefaults": {
      "php.validate.enable": false,
      "php.suggest.basic": false,

      "php.executablePath": "/usr/bin/php",

      "phpParameterHint.hintOnlyLine": false,
      "editor.inlayHints.fontSize": 11,
      "editor.inlayHints.fontFamily": "JetBrains Mono",
      "workbench.colorCustomizations": {
        "editorInlayHint.foreground": "#777777",
        "editorInlayHint.background": "#f5f5f5"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rizort/vscode-phpstorm-pack"
  }
}
